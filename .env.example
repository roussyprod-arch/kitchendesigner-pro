# ═════════════════════════════════════════════════════
# ENVIRONNEMENT
# ═════════════════════════════════════════════════════
NODE_ENV=development
PORT=5000
LOG_LEVEL=debug

# ═════════════════════════════════════════════════════
# BASE DE DONNÉES - MONGODB
# ═════════════════════════════════════════════════════
MONGODB_URI=mongodb://localhost:27017/kitchendesigner
MONGODB_USER=admin
MONGODB_PASSWORD=SecurePassword123!
MONGODB_TEST_URI=mongodb://localhost:27017/kitchendesigner-test

# ═════════════════════════════════════════════════════
# JWT - AUTHENTIFICATION
# ═════════════════════════════════════════════════════
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_REFRESH_EXPIRE=30d

# ═════════════════════════════════════════════════════
# EMAIL - SMTP
# ═════════════════════════════════════════════════════
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
SMTP_FROM=noreply@kitchendesigner.com
SMTP_FROM_NAME=KitchenDesigner Pro

# ═════════════════════════════════════════════════════
# PAIEMENTS - STRIPE
# ═════════════════════════════════════════════════════
STRIPE_PUBLIC_KEY=pk_test_51234567890abcdef
STRIPE_SECRET_KEY=sk_test_51234567890abcdef
STRIPE_WEBHOOK_SECRET=whsec_1234567890abcdef
STRIPE_SUCCESS_URL=http://localhost:3000/payment/success
STRIPE_CANCEL_URL=http://localhost:3000/payment/cancel

# ═════════════════════════════════════════════════════
# STOCKAGE - AWS S3
# ═════════════════════════════════════════════════════
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET=kitchendesigner-bucket
AWS_REGION=eu-west-1
AWS_S3_URL=https://kitchendesigner-bucket.s3.eu-west-1.amazonaws.com

# ═════════════════════════════════════════════════════
# CACHE - REDIS
# ═════════════════════════════════════════════════════
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=RedisPassword123!
REDIS_DB=0
REDIS_CACHE_TTL=3600

# ═════════════════════════════════════════════════════
# URLS
# ═════════════════════════════════════════════════════
API_BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
APP_NAME=KitchenDesigner Pro
APP_VERSION=1.0.0

# ═════════════════════════════════════════════════════
# CORS
# ═════════════════════════════════════════════════════
CORS_ORIGIN=http://localhost:3000,http://localhost:8000,https://kitchendesigner.com
CORS_CREDENTIALS=true

# ═════════════════════════════════════════════════════
# RATE LIMITING
# ═════════════════════════════════════════════════════
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ═════════════════════════════════════════════════════
# LOGS
# ═════════════════════════════════════════════════════
LOG_FILE=logs/app.log
LOG_ERROR_FILE=logs/error.log
LOG_DIR=logs

# ═════════════════════════════════════════════════════
# FEATURES
# ═════════════════════════════════════════════════════
ENABLE_3D_VIEWER=true
ENABLE_PAYMENT=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_TWO_FACTOR=false

# ═════════════════════════════════════════════════════
# SANDBOX/TESTING
# ═════════════════════════════════════════════════════
SANDBOX_MODE=false
DEMO_MODE=false
